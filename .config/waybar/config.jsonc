// -*- mode: jsonc; -*-
{
    // --- GENERAL ---
    "layer": "top",
    "position": "top",
    "margin-left": 24,
    "margin-right": 24,
    "margin-top": 24,

    // --- LEFT MODULES ---
    "modules-left": ["custom/menu","hyprland/workspaces"],

    "hyprland/window": { 
        "format": "{}",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",

    },

    "custom/menu": {
        "format": "Όας",
        "on-click": "~/.config/hypr/scripts/dashboard" 
    },

    "hyprland/workspaces": {
         "sort-by-name": true,
        "format": "{icon}",
        "show-special": true,
        "persistent-workspaces": {"*": 10 },
        "format-icons": {
          "active": "Όχ┤", 
          "empty": "ΎΕΝ",
          "default": "ΎΕΝ"
        }
     },


    // --- CENTER MODULES ---
    "modules-center": ["clock"],

    "clock": {
        "interval": 1,
        "format": "ΎΑΩ {:%H:%M:%S %d %b}",
        },


    // --- RIGHT MODULES ---
    "modules-right": ["network", "battery", "pulseaudio","cpu", "memory", "custom/lock", "custom/power"],

    "network": {
        "format-wifi": "ΎΘτ ",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr}\n{essid} on {frequency}GHz",
        "format-ethernet": "{ipaddr} ΎηΨ",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
        "on-click": "nm-connection-editor"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },

    "pulseaudio": { // TODO: replace with wireplumber
        "format":                 "{volume}%",
        "format-bluetooth":       "{volume}% ≤░Γψ",
        "format-bluetooth-muted": "ΎΣο {icon} ≤░Γψ",
        "format-muted":           "ΎΣο {format_source}",
        "format-source":          "ΎΕ░{volume}%",
        "format-icons": {
          "mute": "Ύγσ",
          "default": ["ΎΑο", "ΎΑπ", "ΎΑπ", "ΎΑρ"]
        },
        "max-length": 25,
        "tooltip": false,
        "onclick": "pamixer -t",

    },
    // --- CENTER MODULES ---
    

    "cpu": {
        "interval": 10,
        "format": "{usage}% ΎΤ╝ ",
        "on-click": "htop"
    },

    "memory": {
        "interval": 10,
        "format": "{}% ΌΚο ",
        "on-click": "htop"
    },

    "temperature": {
        "interval": 30,
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C ΎΜΚ",
        "on-click": "htop"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },


    "custom/updates": {
        "interval": 3600, // every hour
        "exec": "~/.config/waybar/scripts/get_updates.sh",
        "return-type": "json",
        "exec-if": "exit 0",
        "exec-on-event": false,
        "on-click": "terminator sh -c ~/.config/waybar/scripts/update.sh",
        "signal": 8
    },

    "custom/dunst": {
        "exec": "~/.config/waybar/scripts/dunst.sh",
        "return-type": "json",
        "on-click": "dunstctl set-paused toggle"
    },

    // ---

    "tray": {
        "icon-size": 15,
        "spacing": 10
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ΎΔπ",
        "format-icons": ["≤░ΓΟ", "≤░Β╗", "≤░Β╝", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    },

    "bluetooth": {
      "format": "ΎΛΦ",
      "onclick": "blueberry",
      "format-disabled": "", // an empty format will hide the module
      "format-connected": "ΎΛΦ",
      "tooltip-format": "{controller_alias}\\t{controller_address}",
      "tooltip-format-connected": "{controller_alias}\\t{controller_address}\\n\\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\\t{device_address}"
    },
    // ---

    "custom/lock": {
        "tooltip": false,
        "on-click": "swaylock",
        "format": "ΎΑμ"
    },

    "custom/power": {
        "tooltip": false,
        "on-click": "logout",
        "format": "έΠ╗"
    }
}
