@theme "mocha"

configuration{
    modi: "run,drun,window";
    font: "JetBrainsMono Nerd Font Mono Medium 15";
  
    show-icons: false;
    icon-theme: "We10X-special-dark";
    terminal: "alacritty";

    drun-display-format: "{icon} {name}";
    location: 1;
    disable-history: false;
    hide-scrollbar: true;

    display-drun: " ";
    display-run: " ";
    display-window: " ";
    sidebar-mode: true;

    kb-mode-next: "ALt+l";
    kb-mode-previous: "ALt+j";

}


element-text, element-icon , mode-switcher {
    background-color: inherit;
    text-color:       inherit;
}

window {
    background-color: #1e1e2ebb;
    border: 2px;
    border-radius: 15px;

}

* {
  background-color: #00000000;
}

mainbox {

 }

inputbar {
    children: [entry];

    border-radius: 10px;
    padding: 0px;
}

prompt {
    text-color: @green;
    border-radius: 10px;
    margin: 12px 0px 0px 20px;
}

entry {
    padding: 10px;
    margin: 20px 0px 0px 10px;
    text-color: @text;
}

listview {

}

element {
    padding: 3px;
    text-color: @text;
}


element selected {
    background-color: @green;
    text-color: @mantle;
    border-radius: 10px;
}

mode-switcher {
    spacing: 0;
    border-radius: 10px;
}

button {
    padding: 10px;
    margin: 5px;
    text-color: @subtext1;
    font: "JetBrainsMono Nerd Font Mono Medium 24";
    vertical-align: 0.5;
    horizontal-align: 0.5;
    border-radius: 10px;

}

button selected {
  text-color: @green;
}
