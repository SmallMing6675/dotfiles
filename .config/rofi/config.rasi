@theme "mocha"

configuration{
    modi: "run,drun,window";
    font: "JetBrainsMono Nerd Font Mono Medium 15";
  
    show-icons: false;
    icon-theme: "We10X-special-dark";
    terminal: "alacritty";

    drun-display-format: "{icon} {name}";
    location: 3;
    disable-history: false;
    hide-scrollbar: true;

    display-drun: " ";
    display-run: " ";
    display-window: " ";
    sidebar-mode: true;

    kb-mode-next: "ALt+l";
    kb-mode-previous: "ALt+j";

}


element-text, element-icon , mode-switcher {
    background-color: inherit;
    text-color:       inherit;
}

window {
    background-color: #1e1e2edd;
    border-radius: 10px;
}

* {
  background-color: #00000000;
}

mainbox {

 }

inputbar {
    children: [entry];

    border-radius: 5px;
    padding: 0px;
}

prompt {
    padding: 20px;
    text-color: @green;
    content: "->";
    border-radius: 10px;
    margin: 12px 0px 0px 8px;
}

textbox-prompt-colon {
    expand: false;
    str: "-";
}

entry {
    padding: 10px;
    margin: 20px 0px 0px 10px;
    text-color: @fg-col;
}

listview {

}

element {
    padding: 3px;
    text-color: @fg-col;
}

element-icon {
    size: 30px;
}

element selected {
    text-color: @green;
    border-radius: 10px;
}

mode-switcher {
    background-color: @bg-col-light;
    spacing: 0;
    border-radius: 10px;
}

button {
    padding: 10px;
    margin: 5px;
    text-color: @grey;
    font: "JetBrainsMono Nerd Font Mono Medium 20";
    vertical-align: 0.5;
    horizontal-align: 0.5;
    border-radius: 10px;

}

button selected {
  text-color: @green;
}
